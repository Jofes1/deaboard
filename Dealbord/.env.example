# Kopiera den här filen till .env och fyll i dina värden
# Hitta dessa i Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://ditt-projekt-id.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-nyckel-här

# Lösenord för admin-gränssnittet på /admin
VITE_ADMIN_PASSWORD=byt-ut-detta-lösenord
